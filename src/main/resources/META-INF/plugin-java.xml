    <listener topic="com.intellij.openapi.compiler.CompilationStatusListener"
      class="at.s2gplus.ai.ProjectCompilationStatusListener" />
  </projectListeners>

  <extensions defaultExtensionNs="com.intellij">
    <applicationService
      serviceImplementation="at.s2gplus.ai.codecompletions.psi.JavaContextFinder"/>
  </extensions>
</idea-plugin>